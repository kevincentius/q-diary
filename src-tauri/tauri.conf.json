{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "q-diary",
  "version": "0.1.0",
  "identifier": "com.qdiary.desktop",
  "build": {
    "frontendDist": "../dist/client/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npx nx run client:serve",
    "beforeBuildCommand": "npx nx run client:build"
  },
  "app": {
    "windows": [
      {
        "title": "Q-Diary",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": []
    }
  }
}
